# 공용 Supabase 프로젝트(common)를 다른 앱들과 함께 사용
# 실제 값은 project-command-center/.secrets/supabase/projects.json 참고
#
# 이 앱(todo-ran)은 todoran 스키마를 쓴다.
# 스키마 라우팅은 src/lib/supabase/client.ts에서 db.schema 옵션으로 처리.

NEXT_PUBLIC_SUPABASE_URL=https://cfdkabflrgphwpfmkzvh.supabase.co

# Publishable key (= 옛 anon key) — Supabase 대시보드
#   Project Settings → API Keys → Publishable and secret API keys → Publishable key
# 브라우저에 노출돼도 안전 (RLS가 데이터 보호). sb_publishable_... 형태.
# Secret key는 todo-ran에서 안 씀 (백엔드 서버 없는 구조).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# 관리자 은닉 경로 세그먼트 — /_c/<이 값> 이 관리자 라우트가 됨.
# 서버 전용 (NEXT_PUBLIC_ 아님, 브라우저 번들에 안 들어감).
# 미설정 상태에서는 /_c/* 접근이 전부 404.
#
# 값 규칙:
#   - 영숫자+하이픈, 3자 이상
#   - 짧게(3~6자) 두면 타이핑 편함, 봇 워드리스트 회피는 "예측 불가능성"이 관건
#   - 예: x7k9, c-42a, r0mn
#
# 유출 시 대응: Vercel Project Settings → Environment Variables에서 값만 교체
#   → Redeploy. 코드 변경/커밋 필요 없음.
ADMIN_PATH_SEGMENT=change-me
